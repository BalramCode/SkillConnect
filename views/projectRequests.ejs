<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifications Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <div class="max-w-7xl mx-auto  px-6">
      
      <nav
        class="bg-white sticky top-0 z-30 shadow-sm flex justify-between p-4 items-center h-16 border-b border-gray-100 mb-8">
        <div class="font-bold text-2xl text-gray-800 ml-6">Notifications</div>
      
        <div class="relative w-96 hidden md:block">
          <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400"
            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 1114 0z" />
          </svg>
          <input
            class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-150 text-sm"
            type="text" placeholder="Search projects, requests..." />
        </div>
      <% 
    // This check prevents the "is not defined" error
              let incomingCount = 0; 
              if (typeof creatorProjects !== 'undefined' && creatorProjects) { 
                  creatorProjects.forEach(p => { 
                      if (p.joinRequests) {
                          incomingCount += p.joinRequests.filter(r => r.status === 'pending').length; 
                      }
                  }); 
              } 
          %>

          <a href="/requestRoute/notifications" class="relative group p-2 rounded-full hover:bg-gray-100 transition-all duration-200">
            <svg class="relative left-3 w-6 h-6 text-gray-500 hover:text-gray-700 transition" xmlns="http://www.w3.org/2000/svg"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 22c1.1 0 2-.9 2-2h-4a2 2 0 002 2zm6-6v-5a6 6 0 10-12 0v5l-2 2v1h16v-1l-2-2z" />
            </svg>

            <% if (incomingCount > 0) { %>
              <span class="absolute top-1 right-1 flex h-5 w-5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                <span class="relative inline-flex items-center justify-center rounded-full h-5 w-5 bg-red-600 text-[10px] font-bold text-white border-2 border-white">
                  <%= incomingCount %>
                </span>
              </span>
            <% } %>
          </a>
        <div class="flex items-center gap-3 pr-6">
          <div
            class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-800 font-bold border border-indigo-200">
            <% const fullName=user.fullname || user.username; const nameParts=fullName.split(' ').filter(part => part.length > 0); 
              let initials = ''; 
              if (nameParts.length === 1) { 
                initials = nameParts[0].substring(0, 2).toUpperCase(); 
              } else if (nameParts.length >= 2) { 
                initials = (nameParts[0].charAt(0) + nameParts[nameParts.length - 1].charAt(0)).toUpperCase(); 
              } 
            %> 
            <%= initials %>
          </div>
          
          <div class="flex flex-col justify-center">
            <p class="font-bold text-gray-800 leading-none text-sm">
              <%= user.fullname || user.username %>
            </p>
            <p class="text-xs text-gray-500 leading-none mt-1">
              <%= user.university || ' Member' %>
              </p>
          </div>
        </div>
      </nav>

<div class="max-w-7xl mx-auto px-6 pb-12">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
    
    <section class="lg:col-span-7 space-y-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-black uppercase tracking-widest text-gray-400">Your Sent Requests</h2>
        <span class="h-px flex-grow ml-4 bg-gray-100"></span>
      </div>
      
      </section>

    <section class="lg:col-span-5 space-y-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-black uppercase tracking-widest text-gray-400">Requests on Your Projects</h2>
        <span class="h-px flex-grow ml-4 bg-gray-100"></span>
      </div>

      </section>
  </div>
</div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <section class="lg:col-span-7 space-y-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="p-1.5 bg-indigo-100 text-indigo-600 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
            </span>
            <h2 class="text-lg font-bold text-slate-800">Your Sent Requests</h2>
          </div>

          <div class="space-y-3">
            <% let foundRequests=false; %>
              <% userJoinRequests.forEach(project=> { %>
                <% // FIND only the specific request made by the current user for THIS project const
                  myRequest=project.joinRequests.find(r=> r.user._id.toString() === user._id.toString());
                  if (myRequest) {
                  foundRequests = true;
                  %>
                  <div class="bg-white border border-slate-200 rounded-xl p-4 flex items-center justify-between">
                    <div>
                      <span class="text-[10px] font-bold text-slate-400 uppercase">Project</span>
                      <p class="font-semibold text-slate-800">
                        <%= project.projectName %>
                      </p>
                    </div>
          
                    <div class="text-right">
                      <% if (myRequest.status==="accepted" ) { %>
                        <span class="text-xs font-bold text-green-600 bg-green-50 px-2 py-1 rounded-full">Accepted</span>
                        <% } else if (myRequest.status==="rejected" ) { %>
                          <span class="text-xs font-bold text-red-600 bg-red-50 px-2 py-1 rounded-full">Rejected</span>
                          <% } else { %>
                            <span class="text-xs font-bold text-amber-600 bg-amber-50 px-2 py-1 rounded-full">Pending</span>
                            <% } %>
                    </div>
                  </div>
                  <% } %>
                    <% }); %>
          
                      <% if (!foundRequests) { %>
                        <p class="text-slate-400 text-center py-10">No requests sent yet.</p>
                        <% } %>
          </div>
        </section>

        <section class="lg:col-span-5 space-y-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="p-1.5 bg-emerald-100 text-emerald-600 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                </svg>
            </span>
            <h2 class="text-lg font-bold text-slate-800">Incoming Requests</h2>
          </div>

          <div class="space-y-4 max-h-[70vh] overflow-y-auto custom-scrollbar pr-2">
            <% let creatorDataFound = false; creatorProjects.forEach(project => { if (project.joinRequests.length > 0) { 
              creatorDataFound = true; %>

              <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                <div class="px-4 py-2 border-b border-slate-50 bg-slate-50/50 flex justify-between items-center">
                  <span class="text-[10px] font-black text-slate-400 uppercase">On: <%= project.projectName %></span>
                  <span class="text-[10px] px-1.5 py-0.5 bg-white border rounded text-slate-500"><%= project.joinRequests.length %> New</span>
                </div>

                <div class="divide-y divide-slate-50">
                  <% project.joinRequests.forEach(r => { %>
                    <div class="p-4">
                      <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-3">
                          <div class="h-9 w-9 rounded-lg bg-slate-100 flex items-center justify-center text-slate-700 font-bold border border-slate-200">
                            <%= r.user.username.charAt(0).toUpperCase() %>
                          </div>
                          <div>
                            <p class="text-sm font-bold text-slate-800"><%= r.user.username %></p>
                            <p class="text-[11px] text-slate-400">Requesting to join</p>
                          </div>
                        </div>
                      </div>

                      <div class="flex items-center gap-2">
                        <a href="/requestRoute/project/<%= project._id %>/reject/<%= r.user._id %>" 
                           class="flex-1 text-center py-2 text-xs font-bold text-slate-500 bg-slate-50 hover:bg-red-50 hover:text-red-600 rounded-lg transition-colors">
                          Decline
                        </a>
                        <a href="/requestRoute/project/<%= project._id %>/accept/<%= r.user._id %>" 
                           class="flex-1 text-center py-2 text-xs font-bold bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-all shadow-sm">
                          Approve
                        </a>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>

            <% } }); if (!creatorDataFound) { %>
              <div class="bg-slate-100/50 border border-dashed border-slate-200 rounded-2xl py-12 text-center">
                <p class="text-slate-400 text-sm italic">Clean slate! No pending project requests.</p>
              </div>
            <% } %>
          </div>
        </section>

      </div>
    </div>

    <% if (message) { %>
      <div id="toast" class="fixed bottom-8 right-8 z-50 flex items-center gap-3 bg-slate-900 text-white px-5 py-3.5 rounded-2xl shadow-2xl border border-slate-700 transition-opacity duration-500">
        <div class="flex-shrink-0 h-2 w-2 rounded-full <%= message === 'accepted' ? 'bg-green-400' : 'bg-red-400' %>"></div>
        <p class="text-sm font-semibold tracking-tight">Request <%= message %>!</p>
      </div>

      <script>
        setTimeout(() => {
          const toast = document.getElementById("toast");
          toast.classList.add("opacity-0");
          setTimeout(() => toast.remove(), 600);
        }, 3000);
      </script>
    <% } %>
  </body>
</html>